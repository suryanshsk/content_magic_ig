# ── COPY THIS FILE TO .env AND FILL IN YOUR KEYS ──────────────────────────
# NEVER commit .env to GitHub — it's in .gitignore

# Scraper mode
# rapidapi_only = never call Apify
# hybrid        = Apify primary + RapidAPI fallback
SCRAPER_MODE=hybrid
SCRAPE_INTERVAL_HOURS=1
ENABLE_HOURLY_DIGEST=1
TELEGRAM_DIGEST_CHUNK_SIZE=10
TELEGRAM_DIGEST_REELS_PER_CREATOR=5
ENABLE_HOURLY_AI_INSIGHTS=1
HOURLY_AI_TOP_CREATORS=8

# Apify (free tier: 100 actor runs/month)
# Get at: https://console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=your_apify_token_here
# Safety cap before hard limit; set 100 if you want full free-tier usage.
APIFY_MONTHLY_LIMIT=95

# RapidAPI — Instagram Scraper Stable API (free/paid plans depend on provider)
# Get at: https://rapidapi.com/thetechguy32744/api/instagram-scraper-stable-api
# Subscribe to a plan, then copy X-RapidAPI-Key from endpoint page
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_MONTHLY_LIMIT=480
RAPIDAPI_HOST=instagram-scraper-stable-api.p.rapidapi.com
RAPIDAPI_BASE_URL=https://instagram-scraper-stable-api.p.rapidapi.com

# Optional tertiary fallback when Apify + RapidAPI fail or hit limits.
# Requires Node.js and an Instagram web session cookie from your browser.
ENABLE_INSTATOUCH_FALLBACK=1
# Format example: sessionid=abcd1234...;
INSTATOUCH_SESSION=
# If enabled and INSTATOUCH_SESSION is empty, the app tries to read Instagram
# sessionid from your local logged-in browser cookies (Chrome/Edge/Brave).
# Safety default is OFF to avoid accidental use of your primary logged-in account.
AUTO_FETCH_INSTAGRAM_SESSION=0
INSTATOUCH_NPX_COMMAND=npx
INSTATOUCH_TIMEOUT_MS=1200
# Safety controls for fallback mode
INSTATOUCH_MAX_CREATORS_PER_RUN=8
INSTATOUCH_COOLDOWN_SECONDS=8

# Telegram Bot (completely free)
# 1. Open Telegram → search @BotFather → send /newbot → copy the token
# 2. Start a chat with your new bot
# 3. Message @userinfobot to get your personal Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Anthropic Claude API (daily idea generation — ~$2–5/month)
# Get at: https://console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets credentials (path to your service account JSON file)
# See README.md Step 4 for full setup instructions
GOOGLE_SHEETS_CREDS=credentials.json

# Optional: exact existing sheet to open (recommended in production)
GOOGLE_SHEET_NAME=ContentMagic_suryanshsk
# Optional alternative: use spreadsheet ID from its URL
# GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890
