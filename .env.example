# ── COPY THIS FILE TO .env AND FILL IN YOUR KEYS ──────────────────────────
# NEVER commit .env to GitHub — it's in .gitignore

# Scraper mode
# rapidapi_only = never call Apify
# hybrid        = Apify primary + RapidAPI fallback
SCRAPER_MODE=hybrid
SCRAPE_INTERVAL_HOURS=1
ENABLE_HOURLY_DIGEST=1
TELEGRAM_DIGEST_CHUNK_SIZE=10
TELEGRAM_DIGEST_REELS_PER_CREATOR=5
ENABLE_HOURLY_AI_INSIGHTS=1
HOURLY_AI_TOP_CREATORS=8

# Apify (free tier: 100 actor runs/month)
# Get at: https://console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=your_apify_token_here

# RapidAPI — Instagram Scraper API2 by hemanth (free tier: 500 calls/month)
# Get at: https://rapidapi.com/hemanth.harikrishnan/api/instagram-scraper-api2
# Subscribe to Basic (free) → copy X-RapidAPI-Key from the endpoint page
RAPIDAPI_KEY=your_rapidapi_key_here
# Must match the API product you subscribed to.
# Current code expects "Instagram Scraper API2" endpoints: /info and /posts
RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com
RAPIDAPI_BASE_URL=https://instagram-scraper-api2.p.rapidapi.com/v1

# Telegram Bot (completely free)
# 1. Open Telegram → search @BotFather → send /newbot → copy the token
# 2. Start a chat with your new bot
# 3. Message @userinfobot to get your personal Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Anthropic Claude API (daily idea generation — ~$2–5/month)
# Get at: https://console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets credentials (path to your service account JSON file)
# See README.md Step 4 for full setup instructions
GOOGLE_SHEETS_CREDS=credentials.json

# Optional: exact existing sheet to open (recommended in production)
GOOGLE_SHEET_NAME=ContentMagic_suryanshsk
# Optional alternative: use spreadsheet ID from its URL
# GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890
