# ── COPY THIS FILE TO .env AND FILL IN YOUR KEYS ──────────────────────────
# NEVER commit .env to GitHub — it's in .gitignore

# Apify (free tier: 100 actor runs/month)
# Get at: https://console.apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=your_apify_token_here

# RapidAPI — Instagram Scraper API2 by hemanth (free tier: 500 calls/month)
# Get at: https://rapidapi.com/hemanth.harikrishnan/api/instagram-scraper-api2
# Subscribe to Basic (free) → copy X-RapidAPI-Key from the endpoint page
RAPIDAPI_KEY=your_rapidapi_key_here

# Telegram Bot (completely free)
# 1. Open Telegram → search @BotFather → send /newbot → copy the token
# 2. Start a chat with your new bot
# 3. Message @userinfobot to get your personal Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Anthropic Claude API (daily idea generation — ~$2–5/month)
# Get at: https://console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets credentials (path to your service account JSON file)
# See README.md Step 4 for full setup instructions
GOOGLE_SHEETS_CREDS=credentials.json
